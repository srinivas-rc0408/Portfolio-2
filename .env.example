# Copy to .env.local and fill in. .env.local is gitignored.

# Production site URL — used for canonical + OpenGraph URLs (SEO).
# Set this to your custom domain once you have one. On Vercel, if left blank,
# it auto-falls back to NEXT_PUBLIC_VERCEL_URL. Dev falls back to localhost.
NEXT_PUBLIC_SITE_URL=

# Fluxbase — backend data layer (REST /api/execute-sql). Server-side only.
FLUXBASE_URL=https://fluxbase.vercel.app/api/execute-sql
FLUXBASE_API_KEY=
FLUXBASE_PROJECT_ID=

# Admin credentials (server-side only)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Session signing secret — REQUIRED in production (app refuses to boot without
# it). Generate a long random value, e.g.  openssl rand -base64 48
AUTH_SECRET=

# AI backend — three-tier fallback (Tier 1 NVIDIA → Tier 2 NVIDIA → Tier 3 Gemini).
# Default model is a fast low-latency variant; override here if desired.
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Resend — transactional email (welcome email on registration). Server-side only.
# Sending to arbitrary registrants needs a verified domain; onboarding@resend.dev
# only delivers to the Resend account owner (test mode).
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# Upstash Redis (REST) — distributed rate limiting across serverless instances.
# Optional: when unset, the limiter falls back to an in-memory window.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
