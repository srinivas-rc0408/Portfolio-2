# Copy to .env.local and fill in. .env.local is gitignored.

# Neon Postgres connection string
DATABASE_URL=

# Admin credentials (server-side only)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Session signing secret — REQUIRED in production (app refuses to boot without
# it). Generate a long random value, e.g.  openssl rand -base64 48
AUTH_SECRET=

# AI backend — three-tier fallback (Tier 1 NVIDIA → Tier 2 NVIDIA → Tier 3 Gemini).
# Default model is a fast low-latency variant; override here if desired.
NVIDIA_API_KEY_1=
NVIDIA_API_KEY_2=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
